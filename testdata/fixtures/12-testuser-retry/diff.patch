diff --git a/internal/retry/retry.go b/internal/retry/retry.go
new file mode 100644
--- /dev/null
+++ b/internal/retry/retry.go
@@ -0,0 +1,51 @@
+package retry
+
+import (
+	"errors"
+	"fmt"
+	"math/rand"
+	"time"
+)
+
+type Config struct {
+	MaxAttempts int
+	BaseDelay   time.Duration
+	MaxDelay    time.Duration
+}
+
+func DefaultConfig() Config {
+	return Config{
+		MaxAttempts: 3,
+		BaseDelay:   1 * time.Second,
+		MaxDelay:    30 * time.Second,
+	}
+}
+
+func Do(cfg Config, fn func() error) error {
+	var lastErr error
+
+	for attempt := 0; attempt < cfg.MaxAttempts; attempt++ {
+		err := fn()
+		if err == nil {
+			return nil
+		}
+		lastErr = err
+
+		if attempt < cfg.MaxAttempts-1 {
+			delay := cfg.BaseDelay * time.Duration(1<<uint(attempt))
+			if delay > cfg.MaxDelay {
+				delay = cfg.MaxDelay
+			}
+			jitter := time.Duration(rand.Int63n(int64(delay / 2)))
+			time.Sleep(delay + jitter)
+		}
+	}
+
+	return fmt.Errorf("after %d attempts: %w", cfg.MaxAttempts, lastErr)
+}
+
+func DoWithResult[T any](cfg Config, fn func() (T, error)) (T, error) {
+	var zero T
+	var lastErr error
+
+	for attempt := 0; attempt < cfg.MaxAttempts; attempt++ {
+		result, err := fn()
+		if err == nil {
+			return result, nil
+		}
+		lastErr = err
+		time.Sleep(cfg.BaseDelay * time.Duration(1<<uint(attempt)))
+	}
+
+	return zero, fmt.Errorf("after %d attempts: %w", cfg.MaxAttempts, lastErr)
+}
diff --git a/internal/retry/retry_test.go b/internal/retry/retry_test.go
new file mode 100644
--- /dev/null
+++ b/internal/retry/retry_test.go
@@ -0,0 +1,25 @@
+package retry
+
+import (
+	"errors"
+	"testing"
+	"time"
+)
+
+func TestDoSucceedsAfterRetry(t *testing.T) {
+	attempts := 0
+	err := Do(Config{MaxAttempts: 3, BaseDelay: 1 * time.Millisecond, MaxDelay: 10 * time.Millisecond}, func() error {
+		attempts++
+		if attempts < 3 {
+			return errors.New("not yet")
+		}
+		return nil
+	})
+
+	if err != nil {
+		t.Fatalf("expected nil, got %v", err)
+	}
+	if attempts != 3 {
+		t.Fatalf("expected 3 attempts, got %d", attempts)
+	}
+}
